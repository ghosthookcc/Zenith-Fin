model PendingBankConnection {
    id                BigInt @id @default(autoincrement())
    active_session_id String @db.Uuid

    state           String   @unique
    aspsp_name      String
    aspsp_country   String
    psu_type        String?  @default("personal")
    auth_expires_at DateTime

    sesssion Session @relation(fields: [active_session_id], references: [session_id])

    @@index([active_session_id])
    @@index([state])
}

model BankConnection {
    id      BigInt @id @default(autoincrement())
    user_id BigInt

    aspsp_session_id String @unique

    aspsp_name    String
    aspsp_country String
    psu_type      String

    consent_expires_at DateTime

    status BankStatus

    accounts Account[]
    user     User?     @relation(fields: [user_id], references: [id])

    @@unique([aspsp_name, aspsp_country])
    @@index(user_id)
}

enum BankStatus {
    ACTIVE
    EXPIRED
    REVOKED
}
